{
	"console.log()": {
		"prefix": "console.log()",
		"body": "console.log('$1')",
		"description": "description for console.log()"
	},
	"defineEmits()": {
		"prefix": "vemit",
		"body": "const emit = defineEmits(['$1'])",
		"description": "description for defineEmits()"
	},
	"() => {} 回調函式": {
		"prefix": "callBack",
		"body": [
			"() => {",
			"\t$1",
			"}"
		],
		"description": "description for () => {} 回調函式"
	},
	"try/catch": {
		"prefix": "try/catch",
		"body": [
			"try {",
			"  const result = await foo()",
			"  console.log('result: ',result)",
			"} catch (e) {",
			"  console.error('錯誤：', e)",
			"}"
		],
		"description": "description for try/catch"
	},
	"await to()": {
		"prefix": "await to()",
		"body": [
			"const [e, result] = await to($1)",
			"e ? console.log('$1 失敗', e) : console.log('$1 成功')"
		],
		"description": "description for await to()"
	},
	"onMounted 週期": {
		"prefix": "vonMounted",
		"body": [
			"onMounted(() => {",
			"  $1",
			"})"
		],
		"description": "onMounted"
	},
	"ref() 響應變數": {
		"prefix": "vref()",
		"body": "const $1 = ref($2)",
		"description": "vref()"
	},
	"reactive 響應變數": {
		"prefix": "vreactive()",
		"body": "const $1 = reactive($2)",
		"description": "reactive()"
	},
	"import vue": {
		"prefix": "vimpov",
		"body": "import type { $1 } from \"vue\"",
		"description": "vimpv"
	}

}